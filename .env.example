# ============================================
# متغيرات البيئة - BHD-OM
# ============================================

# قاعدة البيانات
DATABASE_URL="postgresql://user:password@localhost:5432/bhd_om?schema=public"

# التشفير
ENCRYPTION_MASTER_KEY="your-32-char-minimum-master-key-here!!"
HASH_PEPPER="your-random-pepper-string-for-search-hashes-2024"

# Cron Job
CRON_SECRET="your-secure-cron-secret-key"

# CSRF Protection
CSRF_SECRET="your-csrf-secret-key"

# JWT
JWT_SECRET="your-jwt-secret"
JWT_EXPIRES_IN="7d"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
