# قاعدة بيانات حقيقية قابلة للتوسع (10M+ عقار، 1M+ مستخدم)
# استخدم رابط Pooled في الإنتاج (Neon: خيار Pooled، أو Vercel Postgres)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"
# إن ربطتَ Vercel Postgres من لوحة Vercel، غالباً تُحقن تلقائياً POSTGRES_PRISMA_URL و POSTGRES_URL — الكود يقرأها إن لم تُعرّف DATABASE_URL يدوياً.
# Neon: غالباً NEON_DATABASE_URL أو DATABASE_URL — يُضاف sslmode=require تلقائياً للمضيفين غير المحليين إن لم يكن في الرابط.

# NextAuth — مطلوب لتسجيل الدخول
NEXTAUTH_URL="https://www.bhd-om.com"
NEXTAUTH_SECRET="ولّد سلسلة عشوائية: openssl rand -base64 32"

# للتطوير المحلي (اختياري)
# DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/bhd_om"
# NEXTAUTH_URL="http://localhost:3000"

# Thawani (بوابة الدفع) — اختياري؛ بدونها يُستخدم mock محلي
# THAWANI_SECRET_KEY=""
# THAWANI_PUBLISHABLE_KEY=""
# THAWANI_API_BASE="https://checkout.thawani.om/api/v1"
# THAWANI_SUCCESS_URL="https://www.bhd-om.com/ar/payment/success"
# THAWANI_CANCEL_URL="https://www.bhd-om.com/ar/payment/cancel"
# THAWANI_WEBHOOK_SECRET=""
# مراجعة الجاهزية بعد النشر: GET /api/admin/payment-gateway (ADMIN)

# E2E Playwright (CI أو محلي) — seed يُنشئ admin@bhd-om.com / admin123 (نفس CI افتراضياً)
# E2E_BASE_URL="http://localhost:3000"
# E2E_ADMIN_EMAIL="admin@bhd-om.com"
# E2E_ADMIN_PASSWORD="admin123"
# E2E_SECURITY_PIN=""
# E2E_ALLOW_DB_RESET="true"  # فقط لاختبار تصفير DB في critical-flows — خطير على بيانات حقيقية
# E2E_ACCOUNTANT_EMAIL=""
# E2E_ACCOUNTANT_PASSWORD=""
# E2E_OWNER_EMAIL=""
# E2E_OWNER_PASSWORD=""
# E2E_CLIENT_EMAIL=""
# E2E_CLIENT_PASSWORD=""
# E2E_PROPERTY_ID="1"  # عقار ثابت لاختبار happy-path (افتراضي 1)

# بعد سحب تحديثات Prisma على السيرفر:
# npm run db:migrate:deploy
# npm run db:backfill-legacy-booking-settings
# ثم من /admin/data: ترحيل legacy → حذف مفاتيح AppSetting بعد fullyMigrated
# قائمة كاملة: docs/PRODUCTION-CHECKLIST.md
# تحقق سريع: GET https://www.bhd-om.com/api/check-env

# إدارة البيانات /admin/data — الرمز يُخزَّن مشفّراً في DB
# ADMIN_DATA_RESET_PIN="رمز_أولي_8_أحرف_فأكثر"
