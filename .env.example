# ====== مطلوب في الإنتاج (Vercel) ======
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"
NEXTAUTH_URL="https://www.bhd-om.com"
NEXTAUTH_SECRET="openssl rand -base64 32"

# أمان — إلزامي في production (لا قيم افتراضية في الكود)
ENCRYPTION_MASTER_KEY="openssl rand -base64 32"
CRON_SECRET="openssl rand -base64 32"
THAWANI_WEBHOOK_SECRET="from-thawani-dashboard"
ADMIN_DATA_RESET_PIN="رمز_8_أحرف_فأكثر"

# اختياري: rate limit / lockout (افتراضي 5 محاولات / 15 دقيقة)
MAX_LOGIN_ATTEMPTS="5"
LOCKOUT_DURATION_MINUTES="15"

# اختياري — Upstash Redis لـ rate limiting موزّع على Vercel (موصى به)
# UPSTASH_REDIS_REST_URL="https://xxx.upstash.io"
# UPSTASH_REDIS_REST_TOKEN="AX..."

# تطوير محلي فقط — بديل ADMIN_DATA_RESET_PIN إذا لم تُعرّف في .env
# ADMIN_DATA_RESET_PIN_DEV="local-dev-pin-123"

# Thawani
# THAWANI_SECRET_KEY=""
# THAWANI_PUBLISHABLE_KEY=""
# THAWANI_API_BASE="https://checkout.thawani.om/api/v1"
# THAWANI_SUCCESS_URL="https://www.bhd-om.com/ar/payment/success"
# THAWANI_CANCEL_URL="https://www.bhd-om.com/ar/payment/cancel"

# E2E Playwright
# E2E_BASE_URL="http://localhost:3000"
# E2E_ADMIN_EMAIL="admin@bhd-om.com"
# E2E_ADMIN_PASSWORD="admin123"

# بعد النشر — تشفير بيانات قديمة (مرة واحدة، يحتاج DATABASE_URL + ENCRYPTION_MASTER_KEY):
# npm run db:backfill-booking-encryption
# npm run db:backfill-contract-encryption
# npm run db:backfill-contact-pii-encryption
# npm run db:backfill-address-book-encryption
# بعد النشر (ADMIN): GET /api/check-env
