# قاعدة بيانات حقيقية قابلة للتوسع (10M+ عقار، 1M+ مستخدم)
# استخدم رابط Pooled في الإنتاج (Neon: خيار Pooled، أو Vercel Postgres)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# NextAuth — مطلوب لتسجيل الدخول
NEXTAUTH_URL="https://www.bhd-om.com"
NEXTAUTH_SECRET="ولّد سلسلة عشوائية: openssl rand -base64 32"

