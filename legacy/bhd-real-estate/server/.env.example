PORT=3789
# 127.0.0.1 محليًا | 0.0.0.0 داخل Docker أو خادم بعيد
# HOST=127.0.0.1
# NODE_ENV=production

# مسار ملف SQLite (اختياري)
# DATABASE_PATH=C:\dev\عقود الايجار\data\rental.db

# مجلد داخل Dropbox للنسخ الاحتياطي التلقائي (ينشئ المجلد إن لم يكن موجوداً)
DROPBOX_BACKUP_DIR=C:\Users\ahami\BHD International Dropbox\ABDULHAMID ALRAWAHI\RentContractsBackup

# كل كم دقيقة يُنسَخ الملف (0 = إيقاف التكرار التلقائي، يبقى النسخ اليدوي عبر API)
BACKUP_INTERVAL_MINUTES=30

# Proxy للسحابة — نفس المنشأ للواجهة (اختياري)
# CLOUD_API_URL=http://127.0.0.1:3790

# SaaS — مفتاح تسجيل شركات جديدة (فارغ = مسموح في التطوير فقط)
# SAAS_REGISTRATION_SECRET=your-secret-key

# S3 / B2 (اختياري — إن تُركت فارغة يُستخدم FILE_STORAGE_DIR)
# S3_BUCKET=
# S3_REGION=
# S3_ENDPOINT=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
