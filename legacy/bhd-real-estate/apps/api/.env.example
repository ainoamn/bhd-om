# API
PORT=3790
HOST=127.0.0.1
NODE_ENV=development

# PostgreSQL (يطابق deploy/docker-compose.dev.yml)
DATABASE_URL=postgresql://bhd:bhd_dev_secret@127.0.0.1:5432/bhd_cloud

# JWT — غيّر في الإنتاج (32+ حرفاً عشوائياً)
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars-dev
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars-dev
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL_DAYS=30

# CORS
CORS_ORIGINS=http://localhost:3789,http://127.0.0.1:3789,http://localhost:3790

# مرفقات — تخزين محلي (لاحقاً: S3 / B2 عبر نفس storage_key)
FILE_STORAGE_DIR=./data/files

# SaaS — مفتاح تسجيل شركات (اتركه فارغاً للتطوير المحلي)
# SAAS_REGISTRATION_SECRET=

# S3-compatible storage (Backblaze B2, AWS S3, MinIO)
# S3_BUCKET=
# S3_REGION=
# S3_ENDPOINT=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
