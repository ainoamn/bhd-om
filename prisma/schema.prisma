// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema
// قاعدة بيانات حقيقية قابلة للتوسع: 10M+ عقار، 1M+ مستخدم — استخدم PostgreSQL مع Connection Pooling (Neon/Supabase/Citus)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN          // أ - الإدارة
  COMPANY        // ب - شركة عقارية
  CLIENT         // ج - عميل
  OWNER          // د - مالك عقار (اطلاع ومتابعة فقط)
  ORG_MANAGER    // ر - مدير شركة مخول (نفس صلاحيات الشركة على عقاراتها)
}

enum ProjectStatus {
  COMPLETED
  UNDER_DEVELOPMENT
  UNDER_CONSTRUCTION
  PLANNING
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum DocumentType {
  CONTRACT
  INVOICE
  REPORT
  CERTIFICATE
  OTHER
}

model User {
  id                String    @id @default(cuid())
  serialNumber      String    @unique  // USR-A-2025-0001 حسب الدور والسنة
  email             String    @unique
  password          String
  name              String
  phone             String?
  phoneHash         String?   @unique // HMAC للبحث — الهاتف الفعلي مشفّر في phone
  role              UserRole  @default(CLIENT)
  isSuperAdmin      Boolean   @default(false)  // أدمن كامل الصلاحيات
  adminPermissions  String?   // JSON: مصفوفة صلاحيات للأدمن الجزئي، مثل ["MANAGE_USERS","MANAGE_PROPERTIES"]
  organizationId    String?   // موظف شركة → الشركة التابع لها
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  projects          Project[]
  tasks             Task[]
  documents         Document[]
  accounts          Account[]
  organization      Organization?  @relation("OrgMembers", fields: [organizationId], references: [id])
  ownedOrganization Organization?  @relation("OrgOwner")
  createdProperties Property[]
  ownedProperties   Property[]     @relation("PropertyOwner")  // عقارات يملكها (د) — للمتابعة والاطلاع فقط
  subscriptions     Subscription[]
  notifications     Notification[]

  @@index([role])
  @@index([createdAt])
  @@index([email])
  @@index([phoneHash])
  @@index([organizationId])
}

model Project {
  id              String          @id @default(cuid())
  serialNumber    String          @unique  // PRJ-C-2025-0001 حسب الحالة والسنة
  titleAr         String
  titleEn         String
  descriptionAr   String
  descriptionEn   String
  status          ProjectStatus
  locationAr      String
  locationEn      String
  area            Float?
  units           Int?
  startDate       DateTime?
  completionDate  DateTime?
  imageUrl        String?
  images          String          // JSON array of image URLs
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  userId          String
  user            User            @relation(fields: [userId], references: [id])
  tasks           Task[]
  documents       Document[]
  accounts        Account[]
  serialHistory   SerialNumberHistory[]

  @@index([status])
  @@index([createdAt])
}

model Task {
  id              String      @id @default(cuid())
  titleAr         String
  titleEn         String
  descriptionAr   String
  descriptionEn   String
  status          TaskStatus  @default(PENDING)
  dueDate         DateTime?
  completedAt     DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  
  userId          String
  user            User        @relation(fields: [userId], references: [id])
  projectId       String?
  project         Project?    @relation(fields: [projectId], references: [id])
}

model Document {
  id              String        @id @default(cuid())
  titleAr         String
  titleEn         String
  type            DocumentType
  fileUrl         String
  fileName        String
  fileSize        Int
  mimeType        String
  descriptionAr   String?
  descriptionEn   String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  userId          String
  user            User          @relation(fields: [userId], references: [id])
  projectId       String?
  project         Project?      @relation(fields: [projectId], references: [id])
}

model Account {
  id              String    @id @default(cuid())
  accountNumber   String    @unique
  balance         Float     @default(0)
  currency        String    @default("OMR")
  descriptionAr   String?
  descriptionEn   String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  userId          String
  user            User      @relation(fields: [userId], references: [id])
  projectId       String?
  project         Project?  @relation(fields: [projectId], references: [id])
  transactions    Transaction[]
}

model Transaction {
  id              String    @id @default(cuid())
  amount          Float
  type            String    // DEBIT or CREDIT
  descriptionAr   String?
  descriptionEn   String?
  date            DateTime  @default(now())
  createdAt       DateTime  @default(now())
  
  accountId       String
  account         Account   @relation(fields: [accountId], references: [id])
}

model SiteContent {
  id              String    @id @default(cuid())
  key             String    @unique
  contentAr       String
  contentEn       String
  type            String    // TEXT, HTML, IMAGE, etc.
  page            String    // home, about, services, etc.
  section         String?   // hero, services, etc.
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

enum PropertyType {
  RENT
  SALE
  INVESTMENT
}

enum PropertyStatus {
  ACTIVE
  FROZEN
  ARCHIVED
}

model Property {
  id              String          @id @default(cuid())
  serialNumber    String          @unique  // PRP-R-2025-0001 حسب النوع والسنة
  titleAr         String
  titleEn         String
  descriptionAr   String
  descriptionEn   String
  type            PropertyType
  status          PropertyStatus  @default(ACTIVE)
  propertyTypeAr  String
  propertyTypeEn  String
  governorateAr   String
  governorateEn   String
  stateAr         String
  stateEn         String
  villageAr       String
  villageEn       String
  price           Float
  area            Float
  bedrooms        Int?
  bathrooms       Int?
  livingRooms     Int?
  majlis         Int?
  parkingSpaces   Int?
  floors          Int?
  balconies       Int?
  image           String
  images          String?         // JSON array of image URLs
  googleMapsUrl   String?
  lat             Float?
  lng             Float?
  isArchived      Boolean         @default(false)
  createdById     String?         // من أضاف العقار (ب أو ر)
  organizationId  String?         // الشركة (ب) التي تدير العقار
  ownerId         String?         // المالك (د) — يظهر العقار في لوحته للمتابعة والاطلاع فقط
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  createdBy       User?           @relation(fields: [createdById], references: [id])
  organization    Organization?   @relation(fields: [organizationId], references: [id])
  owner           User?           @relation("PropertyOwner", fields: [ownerId], references: [id])
  bookings        PropertyBooking[]
  serialHistory   SerialNumberHistory[]

  @@index([type])
  @@index([status])
  @@index([createdAt])
  @@index([type, status])
  @@index([governorateAr])
  @@index([price])
  @@index([createdById])
  @@index([organizationId])
  @@index([ownerId])
  @@index([isArchived])
  @@index([isArchived, createdAt])
}

model PropertyBooking {
  id              String    @id @default(cuid())
  propertyId      String
  property        Property   @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  name            String
  email           String
  phone           String
  message         String?
  type            String    // BOOKING, VIEWING
  status          String    @default("PENDING") // PENDING, CONFIRMED, CANCELLED
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([propertyId])
  @@index([status])
  @@index([createdAt])
  @@index([propertyId, status])
  @@index([email])
  @@index([type])
}

// عدادات للأرقام المتسلسلة - مفتاح: entity-type-year (مثل PRP-R-2025)
model SerialCounter {
  id        String   @id @default(cuid())
  key       String   @unique  // PRP-R-2025, PRJ-C-2025, USR-A-2025
  lastValue Int      @default(0)
  updatedAt DateTime @updatedAt
}

// أرشيف الأرقام المتسلسلة السابقة عند تغيير نوع العقار أو حالة المشروع
model SerialNumberHistory {
  id            String    @id @default(cuid())
  entityType    String    // PROJECT, PROPERTY
  entityId      String
  serialNumber  String    // الرقم السابق
  typeOrStatus  String    // النوع أو الحالة السابقة
  changedAt     DateTime  @default(now())
  projectId     String?
  project       Project?  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  propertyId    String?
  property      Property? @relation(fields: [propertyId], references: [id], onDelete: Cascade)
}

model ContactSubmission {
  id              String    @id @default(cuid())
  name            String
  email           String
  phone           String?
  message         String?
  type            String    // CONTACT, CALLBACK
  isRead          Boolean   @default(false)
  createdAt       DateTime  @default(now())

  @@index([createdAt])
  @@index([type])
}

/// حجوزات من الواجهة العامة — تُخزّن على الخادم لظهورها في لوحة الإدارة والمحاسبة
model BookingStorage {
  id          String   @id @default(cuid())
  bookingId   String   @unique // BKG-xxx من الواجهة
  data        String   // JSON كامل للحجز (PropertyBooking)
  propertyId  Int?
  status      String?
  bookingType String?
  emailNorm   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([createdAt])
  @@index([updatedAt])
  @@index([propertyId])
  @@index([status])
  @@index([bookingType])
  @@index([propertyId, status])
}

/// جلسات دفع معلّقة — لإكمال الحجز بعد Thawani redirect/webhook
model PaymentPendingStorage {
  id             String   @id @default(cuid())
  sessionId      String   @unique
  userId         String?
  propertyId     Int?
  bookingPayload String
  status         String   @default("PENDING")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([status])
  @@index([userId])
  @@index([propertyId])
  @@index([createdAt])
}

/// عقود الإيجار/البيع — جدول مستقل (مصدر الخادم) مع JSON كامل
model ContractStorage {
  id           String   @id @default(cuid())
  contractId   String   @unique // CNT-xxx
  bookingId    String   @unique
  data         String   // JSON كامل للعقد (RentalContract)
  propertyId   Int?
  status       String?
  contractKind String?
  emailNorm    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([createdAt])
  @@index([updatedAt])
  @@index([propertyId])
  @@index([status])
  @@index([contractKind])
  @@index([bookingId])
  @@index([propertyId, status])
}

/// ملفات مرفوعة من صفحة شروط العقد (مستندات توثيق) — تُخزّن في DB ليعمل الرفع على Vercel بدون Blob
model BookingDocumentFile {
  id        String   @id @default(cuid())
  fileName  String
  mimeType  String?
  content   Bytes
  createdAt DateTime @default(now())

  @@index([createdAt])
}

/// مستندات توثيق الحجز — صف لكل مستند (بدل JSON monolithic في AppSetting)
model BookingDocumentStorage {
  id         String   @id @default(cuid())
  documentId String   @unique // BDOC-xxx
  bookingId  String
  data       String   // JSON كامل (BookingDocument)
  propertyId Int?
  status     String?  // PENDING | UPLOADED | APPROVED | REJECTED
  docTypeId  String?
  isRequired Boolean  @default(false)
  emailNorm  String?  // uploadedBy normalized
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([bookingId])
  @@index([propertyId])
  @@index([status])
  @@index([docTypeId])
  @@index([bookingId, status])
  @@index([propertyId, status])
  @@index([updatedAt])
}

/// شيكات الحجز — صف لكل شيك (بدل JSON monolithic في AppSetting)
model BookingCheckStorage {
  id          String   @id @default(cuid())
  bookingId   String
  checkTypeId String
  data        String   // JSON كامل (BookingCheckEntry)
  propertyId  Int?
  isApproved  Boolean  @default(false)
  isRejected  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([bookingId, checkTypeId])
  @@index([bookingId])
  @@index([propertyId])
  @@index([isApproved])
  @@index([isRejected])
  @@index([bookingId, isApproved])
  @@index([updatedAt])
}

/// دفتر العناوين — جهات الاتصال (مالك، عميل، ...) تُخزّن على الخادم لتعكس في كل الصفحات
model AddressBookContact {
  id            String   @id @default(cuid())
  contactId     String   @unique // معرف الجهة من الواجهة (UUID نمط CNT-...)
  linkedUserId  String?  @unique // ربط بحساب مستخدم — جهة واحدة لكل مستخدم مرتبط
  data          Json     // كائن Contact كامل (من lib/data/addressBook)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([createdAt])
  @@index([updatedAt])
  @@index([contactId])
  @@index([linkedUserId])
}

/// مرفقات دفتر العناوين (بطاقة، جواز، سجل تجاري…) — تخزين دائم في PostgreSQL أو Vercel Blob
model AddressBookContactFile {
  id        String   @id @default(cuid())
  contactId String?
  fieldKey  String?
  fileName  String
  mimeType  String?
  sizeBytes Int?
  blobUrl   String?
  content   Bytes?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([contactId])
  @@index([contactId, fieldKey])
  @@index([createdAt])
}

/// تخزين دائم لبيانات النظام القديم (عقود، عقارات، شيكات، …) — بديل localStorage على bhd-om.com
model LegacyAppKvStore {
  id        String   @id @default(cuid())
  kvKey     String   @unique
  category  String?
  data      String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@index([updatedAt])
  @@index([kvKey])
}

/// ملفات النظام القديم (عقود، شيكات، عقارات، سجل الملفات…) — PostgreSQL / Vercel Blob
model LegacyStoredFile {
  id           String   @id @default(cuid())
  storeContext String?
  storeKey     String?
  fieldKey     String?
  fileName     String
  mimeType     String?
  sizeBytes    Int?
  blobUrl      String?
  content      Bytes?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([storeContext])
  @@index([storeKey])
  @@index([storeContext, storeKey])
  @@index([createdAt])
}

// ========== Global Intelligent Accounting ==========
enum AccountingAccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

enum AccountingDocType {
  INVOICE
  RECEIPT
  QUOTE
  DEPOSIT
  PAYMENT
  JOURNAL
  PURCHASE_INV
  PURCHASE_ORDER
  CREDIT_NOTE
  DEBIT_NOTE
  OTHER
}

enum AccountingDocStatus {
  DRAFT
  PENDING
  APPROVED
  PAID
  CANCELLED
}

enum AccountingEntryStatus {
  DRAFT
  PENDING
  APPROVED
  POSTED
  CANCELLED
}

model AccountingAccount {
  id          String                 @id @default(cuid())
  code        String                 @unique
  nameAr      String
  nameEn      String
  type        AccountingAccountType
  description String?
  balance     Float                  @default(0)
  currency    String                 @default("OMR")
  isActive    Boolean                @default(true)
  parentId    String?
  parent      AccountingAccount?     @relation("AccountHierarchy", fields: [parentId], references: [id])
  children    AccountingAccount[]    @relation("AccountHierarchy")
  journalLines AccountingJournalLine[]
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  
  @@index([type])
  @@index([code])
}

model AccountingJournalEntry {
  id              String    @id @default(cuid())
  serialNumber    String
  version         Int       @default(1)
  date            DateTime
  totalDebit      Float     @default(0)
  totalCredit     Float     @default(0)
  descriptionAr   String?
  descriptionEn   String?
  reference       String?
  status          AccountingEntryStatus @default(PENDING)
  approvedBy      String?
  approvedAt      DateTime?
  postedBy        String?
  postedAt        DateTime?
  documentId      String?
  bankAccountId   String?
  contactId       String?
  createdBy       String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  lines           AccountingJournalLine[]

  @@index([date])
  @@index([status])
  @@index([documentId])
  @@index([bankAccountId])
  @@index([contactId])
  @@index([createdAt])
}

model AccountingJournalLine {
  id            String    @id @default(cuid())
  journalId     String
  accountId     String
  debit         Float     @default(0)
  credit        Float     @default(0)
  descriptionAr String?
  descriptionEn String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  journal       AccountingJournalEntry @relation(fields: [journalId], references: [id], onDelete: Cascade)
  account       AccountingAccount     @relation(fields: [accountId], references: [id])
}

model AccountingDocument {
  id              String    @id @default(cuid())
  serialNumber    String
  type            AccountingDocType
  status          AccountingDocStatus
  date            DateTime
  dueDate         DateTime?
  totalAmount     Float     @default(0)
  vatRate         Float?
  vatAmount       Float?
  netAmount       Float     @default(0)
  descriptionAr   String?
  descriptionEn   String?
  reference       String?
  contactId       String?
  bankAccountId   String?
  propertyId      Int?
  projectId       String?
  attachmentsJson String?   // JSON [{url, name}]
  purchaseOrder   String?
  branch          String?
  journalEntryId  String?
  createdBy       String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([type])
  @@index([status])
  @@index([date])
  @@index([dueDate])
  @@index([contactId])
  @@index([journalEntryId])
  @@index([createdAt])
}

model AccountingFiscalPeriod {
  id        String    @id @default(cuid())
  code      String
  startDate DateTime
  endDate   DateTime
  isLocked  Boolean   @default(false)
  closedAt  DateTime?
  closedBy  String?
}

model AccountingAuditLog {
  id            String   @id @default(cuid())
  timestamp     DateTime @default(now())
  action        String
  entityType    String
  entityId      String
  userId        String?
  reason        String?
  previousState String?
  newState      String?

  @@index([timestamp])
  @@index([entityType, entityId])
  @@index([userId])
}

// RBAC - صلاحيات المحاسبة
enum AccountingPermission {
  ACCOUNT_VIEW
  ACCOUNT_EDIT
  JOURNAL_CREATE
  JOURNAL_APPROVE
  JOURNAL_CANCEL
  DOCUMENT_CREATE
  PERIOD_LOCK
  REPORT_VIEW
  AUDIT_VIEW
}

model UserAccountingRole {
  id        String   @id @default(cuid())
  userId    String
  role      String   // ACCOUNTANT, APPROVER, AUDITOR, ADMIN
  permissions String // JSON array of AccountingPermission
  createdAt  DateTime @default(now())
}

// إعدادات التطبيق (لوحات التحكم، صلاحيات التصنيفات، إلخ) — يُحفظ من لوحة الأدمن ويُقرأ للعميل
model AppSetting {
  id        String   @id @default(cuid())
  key       String   @unique // مثلاً: dashboard_settings
  value     String   // JSON
  updatedAt DateTime @updatedAt

  @@index([updatedAt])
}

// ========== الشركات والموظفين ==========
model Organization {
  id          String    @id @default(cuid())
  nameAr      String
  nameEn      String
  ownerId     String    @unique  // صاحب الشركة (User)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  owner       User      @relation("OrgOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members     User[]    @relation("OrgMembers")
  properties  Property[]
}

// ========== باقات الاشتراك ==========
model Plan {
  id            String   @id @default(cuid())
  code          String   @unique   // basic, standard, premium, enterprise
  nameAr        String
  nameEn        String
  priceMonthly  Float    @default(0)
  priceYearly   Float?   @default(0)
  currency      String   @default("OMR")
  featuresJson   String?  // JSON: قائمة الميزات المعروضة
  limitsJson     String?  // JSON: maxProperties, maxUsers, storageGB, etc.
  permissionsJson String?  // JSON: مصفوفة صلاحيات الباقة [id, id, ...]
  isActive       Boolean  @default(true)
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  subscriptions Subscription[]
}

model Subscription {
  id                 String    @id @default(cuid())
  userId             String
  planId             String
  status             String    @default("active")  // active, expired, cancelled, pending
  startAt            DateTime  @default(now())
  endAt              DateTime
  usageJson          String?   // JSON: استخدام حالي (عقارات، مستخدمين، إلخ)
  receiptDocumentId  String?   // إيصال دفع الباقة الحالية (من المحاسبة)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan        Plan      @relation(fields: [planId], references: [id], onDelete: Restrict)
  changeRequests SubscriptionChangeRequest[]

  @@unique([userId])
  @@index([userId])
  @@index([planId])
  @@index([status])
  @@index([endAt])
}

// سجل الباقات السابقة للمشترك (تواريخ وبيانات كل فترة)
model SubscriptionHistory {
  id                 String    @id @default(cuid())
  userId             String
  planId             String
  planNameAr         String
  planNameEn         String
  startAt            DateTime
  endAt              DateTime
  amountPaid         Float?    // المبلغ المدفوع في هذه الفترة إن وُجد
  receiptDocumentId  String?   // مرجع إيصال الدفع في المحاسبة إن وُجد
  createdAt          DateTime  @default(now())

  @@index([userId])
  @@index([endAt])
}

// طلب ترقية أو تنزيل الباقة من المستخدم
model SubscriptionChangeRequest {
  id            String    @id @default(cuid())
  userId        String
  subscriptionId String
  requestedPlanId String
  direction     String    // upgrade | downgrade
  status        String    @default("pending")  // pending | approved | rejected
  reason        String?   // سبب الطلب (اختياري)
  reviewedAt    DateTime?
  reviewedById  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  subscription  Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([subscriptionId, status])
}

enum NotificationKind {
  BOOKING
  CONTRACT
  PAYMENT
  SYSTEM
  SUBSCRIPTION
  MAINTENANCE
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind      NotificationKind @default(SYSTEM)
  titleAr   String
  titleEn   String
  bodyAr    String?
  bodyEn    String?
  href      String?
  dedupeKey String?          @unique
  readAt    DateTime?
  createdAt DateTime         @default(now())

  @@index([userId, readAt])
  @@index([userId, createdAt])
}

enum MaintenanceStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model MaintenanceRequest {
  id               String            @id @default(cuid())
  propertyId       Int?
  propertyLabelAr  String?
  propertyLabelEn  String?
  descriptionAr    String
  descriptionEn    String?
  status           MaintenanceStatus @default(OPEN)
  priority         String            @default("NORMAL")
  reporterName     String?
  reporterPhone    String?
  reporterUserId   String?
  notes            String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([status])
  @@index([createdAt])
  @@index([reporterUserId, createdAt])
}

// ==========================================
// نظام الأرشفة
// ==========================================

enum ArchiveEntityType {
  PROPERTY
  DOCUMENT
  ACCOUNT
  CONTRACT
  RESERVATION
  USER
}

enum ArchiveAction {
  ARCHIVE
  RESTORE
  AUTO_ARCHIVE
  POLICY_APPLIED
}

enum ArchiveStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
}

model ArchiveRecord {
  id            String          @id @default(cuid())
  entityType    ArchiveEntityType
  entityId      String
  entityTitle   String
  action        ArchiveAction
  status        ArchiveStatus
  reason        String?
  notes         String?
  dataSnapshot  String          @db.Text
  checksum      String
  archivedById  String
  isAutoArchive Boolean         @default(false)
  policyId      String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  
  @@index([entityType, entityId])
  @@index([archivedById])
  @@index([createdAt])
  @@index([status])
}

model ArchiveRestoreLog {
  id            String   @id @default(cuid())
  archiveId     String
  entityType    ArchiveEntityType
  entityId      String
  entityTitle   String
  restoredById  String
  restoredAt    DateTime @default(now())
  success       Boolean
  errorMessage  String?
  dataSnapshot  String?  @db.Text
  
  @@index([archiveId])
  @@index([entityType, entityId])
  @@index([restoredById])
  @@index([restoredAt])
}

model ArchivePolicy {
  id            String   @id @default(cuid())
  name          String
  entityType    ArchiveEntityType
  condition     String   // INACTIVE_DAYS, EXPIRED, MANUAL, CUSTOM
  conditionValue Int?    // عدد الأيام أو القيمة
  isActive      Boolean  @default(true)
  organizationId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@index([entityType, isActive])
  @@index([organizationId])
}

// ==========================================
// نظام التشفير - إدارة المفاتيح
// ==========================================

enum KeyStatus {
  ACTIVE
  ROTATED
  EXPIRED
  REVOKED
}

model EncryptionKey {
  id          String    @id @default(cuid())
  keyId       String    @unique
  keyHash     String
  status      KeyStatus @default(ACTIVE)
  createdAt   DateTime  @default(now())
  rotatedAt   DateTime?
  revokedAt   DateTime?
  
  @@index([keyId])
  @@index([status])
}

// ==========================================
// نظام التدقيق المحسّن
// ==========================================

model AuditLog {
  id          String   @id @default(cuid())
  userId      String?
  action      String
  entityType  String
  entityId    String
  details     String?  @db.Text
  ipAddress   String?
  userAgent   String?
  severity    String   @default("INFO")
  createdAt   DateTime @default(now())
  
  @@index([userId, createdAt])
  @@index([entityType, entityId])
  @@index([action])
  @@index([createdAt])
  @@index([severity])
}


// نظام تقييم المستأجر الذكي (Smart Tenant Scoring)
// ==========================================

enum ScoreCategory {
  RENT_PAYMENT      // تقييم دفع الإيجار
  BILL_PAYMENT      // تقييم دفع الفواتير
  MAINTENANCE       // تقييم طلبات الصيانة
  OVERALL           // التقييم العام
}

enum ScoreLevel {
  EXCELLENT   // ممتاز (90-100)
  GOOD        // جيد (70-89)
  AVERAGE     // متوسط (50-69)
  POOR        // ضعيف (30-49)
  CRITICAL    // حرج (0-29)
}

model TenantScore {
  id            String        @id @default(cuid())
  tenantUserId  String        // معرف المستأجر
  category      ScoreCategory // نوع التقييم
  score         Int           // 0-100
  level         ScoreLevel    // مستوى التقييم
  notes         String?       @db.Text // ملاحظات (سلبية/إيجابية)
  evidenceJson  String?       @db.Text // أدلة التقييم (JSON)
  evaluatedBy   String?       // من قام بالتقييم
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  
  @@unique([tenantUserId, category])
  @@index([tenantUserId, category])
  @@index([tenantUserId, createdAt])
  @@index([score])
  @@index([level])
}

// ==========================================
// التنبيهات والمهام للمستأجر/المالك
// ==========================================

enum AlertType {
  RENT_DUE        // استحقاق إيجار
  RENT_OVERDUE    // إيجار متأخر
  BILL_DUE        // استحقاق فاتورة
  BILL_OVERDUE    // فاتورة متأخرة
  CONTRACT_EXPIRE // انتهاء عقد
  MAINTENANCE     // صيانة
  TASK_ASSIGNED   // مهمة جديدة
  SYSTEM          // تنبيه نظام
}

enum AlertPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AlertStatus {
  UNREAD
  READ
  DISMISSED
}

model TenantAlert {
  id          String        @id @default(cuid())
  userId      String        // المستهدف (مستأجر/مالك)
  type        AlertType
  title       String
  message     String        @db.Text
  priority    AlertPriority @default(MEDIUM)
  status      AlertStatus   @default(UNREAD)
  dueDate     DateTime?     // تاريخ الاستحقاق
  relatedId   String?       // معرف العقد/الفاتورة المرتبطة
  actionUrl   String?       // رابط الإجراء
  createdAt   DateTime      @default(now())
  readAt      DateTime?
  
  @@index([userId, status])
  @@index([userId, type])
  @@index([priority])
  @@index([dueDate])
  @@index([createdAt])
}

// ==========================================
// المهام (Tasks) — مرتبطة بالمستأجر/المالك
// ==========================================

enum TenantTaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum TaskType {
  RENEWAL     // تجديد عقد
  PAYMENT     // دفع
  MAINTENANCE // صيانة
  INSPECTION  // فحص
  DOCUMENT    // مستند
  OTHER       // أخرى
}

model TenantTask {
  id          String           @id @default(cuid())
  assignerId  String           // من أنشأ المهمة (المالك/المدير)
  assigneeId  String           // المكلف (المستأجر/المالك)
  type        TaskType
  title       String
  description String?          @db.Text
  status      TenantTaskStatus @default(PENDING)
  dueDate     DateTime?
  completedAt DateTime?
  relatedId   String?    // عقد/عقار مرتبط
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  
  @@index([assigneeId, status])
  @@index([assigneeId, dueDate])
  @@index([assignerId])
  @@index([type])
  @@index([dueDate])
}

// ==========================================
// المبالغ المستحقة (Due Amounts)
// ==========================================

enum DueType {
  RENT        // إيجار
  BILL        // فاتورة
  DEPOSIT     // تأمين
  PENALTY     // غرامة تأخير
  MAINTENANCE // تكلفة صيانة
  OTHER       // أخرى
}

enum DueStatus {
  PENDING     // مستحق
  OVERDUE     // متأخر
  PAID        // مدفوع
  PARTIAL     // جزئي
  WAIVED      // معفى
}

model DueAmount {
  id          String    @id @default(cuid())
  userId      String    // المستأجر المستحق عليه
  propertyId  String?   // العقار المرتبط
  contractId  String?   // العقد المرتبط
  type        DueType
  amount      Float     // المبلغ
  currency    String    @default("OMR")
  status      DueStatus @default(PENDING)
  dueDate     DateTime  // تاريخ الاستحقاق
  paidAmount  Float     @default(0)
  paidAt      DateTime?
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  @@index([userId, status])
  @@index([userId, dueDate])
  @@index([contractId])
  @@index([status, dueDate])
  @@index([createdAt])
}

// ==========================================
// التوقيع الذكي (Smart Contract Signature)
// ==========================================

enum SignatureMethod {
  OTP_SMS       // OTP عبر SMS
  OTP_EMAIL     // OTP عبر البريد
  DRAW          // رسم التوقيع
  QR_CODE       // QR code
  BIOMETRIC     // بصمة/وجه
}

enum SignatureStatus {
  PENDING     // بانتظار التوقيع
  SENT        // أُرسل للتوقيع
  SIGNED      // موقّع
  REJECTED    // مرفوض
  EXPIRED     // منتهي
}

model SmartSignature {
  id          String           @id @default(cuid())
  contractId  String           // العقد المرتبط
  tenantId    String           // المستأجر
  method      SignatureMethod  // طريقة التوقيع
  status      SignatureStatus  @default(PENDING)
  otpCode     String?          // كود OTP (مشفّر)
  otpSentTo   String?          // رقم/بريد المرسل إليه
  otpExpiry   DateTime?        // انتهاء صلاحية OTP
  signatureData String?        @db.Text // بيانات التوقيع (base64)
  ipAddress   String?          // IP الموقّع
  deviceInfo  String?          // معلومات الجهاز
  signedAt    DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  
  @@index([contractId, status])
  @@index([tenantId, status])
  @@index([status])
  @@index([createdAt])
}

// ==========================================
// الحسابات المنشأة تلقائياً (Auto User Accounts)
// ==========================================

enum AutoAccountStatus {
  PENDING     // بانتظار الإرسال
  SENT        // أُرسلت بيانات الدخول
  ACTIVATED   // مفعّل
  DISABLED    // معطل
}

model AutoUserAccount {
  id              String            @id @default(cuid())
  contactId       String            // رابط بدفتر العناوين
  userId          String?           // رابط بالمستخدم (بعد الإنشاء)
  username        String            @unique // اسم المستخدم التلقائي
  tempPassword    String            // كلمة المرور المؤقتة (مشفّرة)
  role            String            // الدور: TENANT / OWNER / MANAGER
  classification  String            // التصنيف من دفتر العناوين
  status          AutoAccountStatus @default(PENDING)
  sentVia         String?           // طريقة الإرسال: SMS / EMAIL / WHATSAPP
  sentAt          DateTime?
  activatedAt     DateTime?
  createdAt       DateTime          @default(now())
  createdBy       String            // من أنشأ الحساب
  
  @@index([contactId])
  @@index([userId])
  @@index([status])
  @@index([role])
}

