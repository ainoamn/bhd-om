{
  "name": "bhd-om",
  "version": "0.1.0",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/ainoamn/bhd-om.git",
    "web": "https://github.com/ainoamn/bhd-om"
  },
  "scripts": {
    "dev": "next dev",
    "dev:clean": "powershell -ExecutionPolicy Bypass -File ./scripts/start-dev.ps1",
    "sync": "powershell -ExecutionPolicy Bypass -File ./scripts/git-sync.ps1",
    "build": "prisma generate && node scripts/prisma-migrate-deploy.mjs && next build",
    "db:migrate:deploy": "node scripts/prisma-migrate-deploy.mjs",
    "build:log": "powershell -ExecutionPolicy Bypass -File ./tools/build/run-build.ps1",
    "legacy:split-sync": "node scripts/legacy-split-sync.mjs",
    "db:push": "prisma db push",
    "db:backfill-accounting-journal-links": "npx tsx scripts/backfill-accounting-journal-links.ts",
    "db:migrate-serials-bhd": "npx tsx scripts/migrate-serials-to-bhd.ts",
    "db:reset-keep-properties": "npx tsx prisma/reset-keep-properties.ts",
    "db:backfill-legacy-booking-settings": "npx tsx scripts/backfill-legacy-booking-settings.ts",
    "db:backfill-booking-encryption": "npx tsx scripts/backfill-booking-encryption.ts",
    "db:backfill-contract-encryption": "npx tsx scripts/backfill-contract-encryption.ts",
    "db:backfill-contact-pii-encryption": "npx tsx scripts/backfill-contact-pii-encryption.ts",
    "db:backfill-address-book-encryption": "npx tsx scripts/backfill-address-book-encryption.ts",
    "db:backfill-user-phone-encryption": "npx tsx scripts/backfill-user-phone-encryption.ts",
    "db:backfill-legacy-kv-encryption": "npx tsx scripts/backfill-legacy-kv-encryption.ts",
    "db:backfill-all-encryption": "node scripts/run-all-encryption-backfills.mjs",
    "start": "next start",
    "lint": "eslint .",
    "test:e2e": "playwright test",
    "test:e2e:api": "playwright test tests/e2e/api-booking-guards.spec.ts tests/e2e/api-address-book-auth.spec.ts tests/e2e/api-accounting-reports.spec.ts",
    "test:e2e:critical": "playwright test tests/e2e/critical-flows.spec.ts tests/e2e/booking-happy-path.spec.ts",
    "test:e2e:happy": "playwright test tests/e2e/booking-happy-path.spec.ts",
    "test:e2e:verify": "playwright test tests/e2e/api-booking-guards.spec.ts tests/e2e/api-address-book-auth.spec.ts tests/e2e/api-accounting-reports.spec.ts tests/e2e/accounting-hub.spec.ts tests/e2e/booking-happy-path.spec.ts tests/e2e/critical-flows.spec.ts tests/e2e/public-pages.spec.ts",
    "test:ci": "npm run build && npm run test:e2e:verify",
    "test:e2e:perf": "playwright test tests/e2e/perf-navigation.spec.ts",
    "test:unit": "node --import tsx --test tests/unit/*.test.ts",
    "security:audit": "node scripts/security-audit.mjs"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@prisma/adapter-better-sqlite3": "^7.4.0",
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.3.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "@vercel/blob": "^2.3.1",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.6.2",
    "limiter": "^2.1.0",
    "next": "^16.2.2",
    "next-auth": "^4.24.13",
    "next-intl": "^4.8.2",
    "otplib": "^12.0.1",
    "pdf-parse": "^1.1.4",
    "pg": "^8.19.0",
    "prisma": "^7.3.0",
    "qrcode.react": "^4.2.0",
    "rate-limiter-flexible": "^5.0.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.71.1",
    "react-icons": "^5.5.0",
    "stripe": "^22.3.2",
    "tesseract.js": "^5.1.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.0",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/pdf-parse": "^1.1.5",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^16.4.5",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  },
  "overrides": {
    "@hono/node-server": "^1.19.13",
    "esbuild": "^0.28.1",
    "postcss": "^8.5.10",
    "uuid": "^11.1.1"
  }
}
